#!/usr/bin/env bash
set -euo pipefail

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
PROJECT_ROOT="${CLAUDE_PROJECT_DIR:-$PWD}"
PLUGIN_CACHE_ROOT="${CLAUDE_PLUGIN_CACHE_DIR:-$HOME/.claude/plugins/cache}"

if [[ -n "${MAKEITREAL_ENGINE_ROOT:-}" ]]; then
  ENGINE_ROOT="$MAKEITREAL_ENGINE_ROOT"
else
  ENGINE_ROOT=""
  candidate_roots=(
    "$PLUGIN_ROOT/dev-harness"
    "$PLUGIN_ROOT/../makeitreal/dev-harness"
    "$PLUGIN_ROOT/../../makeitreal/dev-harness"
    "$PROJECT_ROOT"
    "$PROJECT_ROOT/dev-harness"
    "$PWD/dev-harness"
  )
  shopt -s nullglob
  for cached_root in "$PLUGIN_CACHE_ROOT"/52g/makeitreal/*/dev-harness "$PLUGIN_CACHE_ROOT"/makeitreal-tools/makeitreal/*/dev-harness; do
    candidate_roots+=("$cached_root")
  done
  shopt -u nullglob

  for candidate in "${candidate_roots[@]}"; do
    if [[ -f "$candidate/bin/harness.mjs" ]]; then
      ENGINE_ROOT="$candidate"
      break
    fi
  done
fi

if [[ -z "$ENGINE_ROOT" || ! -f "$ENGINE_ROOT/bin/harness.mjs" ]]; then
  echo "mir alias: unable to locate makeitreal dev-harness/bin/harness.mjs. Install makeitreal@52g or set MAKEITREAL_ENGINE_ROOT." >&2
  exit 127
fi

exec node "$ENGINE_ROOT/bin/harness.mjs" "$@"
