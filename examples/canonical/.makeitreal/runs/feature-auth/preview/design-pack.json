{
  "apiSpecs": [
    {
      "contractId": "contract.auth.login",
      "kind": "openapi",
      "path": "contracts/auth-login.openapi.json"
    }
  ],
  "architecture": {
    "edges": [
      {
        "contractId": "contract.auth.login",
        "from": "auth-ui",
        "to": "auth-service"
      }
    ],
    "nodes": [
      {
        "id": "auth-ui",
        "label": "Auth UI",
        "responsibilityUnitId": "ru.frontend"
      },
      {
        "id": "auth-service",
        "label": "Auth Service",
        "responsibilityUnitId": "ru.auth-service"
      }
    ]
  },
  "callStacks": [
    {
      "calls": [
        "authClient.login",
        "POST /auth/login"
      ],
      "entrypoint": "LoginForm.submit"
    }
  ],
  "moduleInterfaces": [
    {
      "imports": [
        {
          "allowedUse": "Submit credential payload and consume declared session result only.",
          "contractId": "contract.auth.login",
          "providerResponsibilityUnitId": "ru.auth-service",
          "surface": "POST /auth/login"
        }
      ],
      "moduleName": "Auth UI",
      "owner": "team.frontend",
      "owns": [
        "apps/web/auth/**"
      ],
      "publicSurfaces": [
        {
          "consumers": [
            "Auth page composition",
            "browser interaction tests"
          ],
          "contractIds": [
            "contract.auth.login"
          ],
          "description": "Submits credential input and delegates authentication through the declared auth login contract.",
          "kind": "component-event",
          "name": "LoginForm.submit",
          "signature": {
            "errors": [
              {
                "code": "AUTH_LOGIN_REJECTED",
                "handling": "Surface the declared auth error state; do not infer fallback session behavior.",
                "when": "The auth service rejects the credential payload."
              }
            ],
            "inputs": [
              {
                "description": "User email address collected by the login form.",
                "name": "credentials.email",
                "required": true,
                "type": "string"
              },
              {
                "description": "User password collected by the login form.",
                "name": "credentials.password",
                "required": true,
                "type": "string"
              }
            ],
            "outputs": [
              {
                "description": "Session response returned by contract.auth.login.",
                "name": "sessionResult",
                "type": "AuthSession"
              }
            ]
          }
        }
      ],
      "purpose": "Own credential collection, client-side validation, and rendering of the declared session result.",
      "responsibilityUnitId": "ru.frontend"
    },
    {
      "imports": [],
      "moduleName": "Auth Service",
      "owner": "team.auth",
      "owns": [
        "services/auth/**",
        "contracts/auth-login.openapi.json"
      ],
      "publicSurfaces": [
        {
          "consumers": [
            "ru.frontend"
          ],
          "contractIds": [
            "contract.auth.login"
          ],
          "description": "Authenticates credentials and returns the declared session response.",
          "kind": "http",
          "name": "POST /auth/login",
          "signature": {
            "errors": [
              {
                "code": "401.INVALID_CREDENTIALS",
                "handling": "Return the declared error response; do not issue partial sessions or fallback identities.",
                "when": "Credentials are syntactically valid but authentication fails."
              }
            ],
            "inputs": [
              {
                "description": "Email value from the auth UI.",
                "name": "request.body.email",
                "required": true,
                "type": "string"
              },
              {
                "description": "Password value from the auth UI.",
                "name": "request.body.password",
                "required": true,
                "type": "string"
              }
            ],
            "outputs": [
              {
                "description": "Authenticated session payload defined by the OpenAPI contract.",
                "name": "200.session",
                "type": "AuthSession"
              }
            ]
          }
        }
      ],
      "purpose": "Own login request validation and session issuance behind the OpenAPI contract.",
      "responsibilityUnitId": "ru.auth-service"
    }
  ],
  "prdId": "prd.auth",
  "responsibilityBoundaries": [
    {
      "mayUseContracts": [
        "contract.auth.login"
      ],
      "owns": [
        "apps/web/auth/**"
      ],
      "responsibilityUnitId": "ru.frontend"
    },
    {
      "mayUseContracts": [],
      "owns": [
        "services/auth/**"
      ],
      "responsibilityUnitId": "ru.auth-service"
    }
  ],
  "runId": "feature-auth",
  "schemaVersion": "1.0",
  "sequences": [
    {
      "messages": [
        {
          "from": "User",
          "label": "submit credentials",
          "to": "Auth UI"
        },
        {
          "from": "Auth UI",
          "label": "POST /auth/login",
          "to": "Auth Service"
        },
        {
          "from": "Auth Service",
          "label": "return session result",
          "to": "Auth UI"
        }
      ],
      "participants": [
        "User",
        "Auth UI",
        "Auth Service"
      ],
      "title": "Login request"
    }
  ],
  "stateFlow": {
