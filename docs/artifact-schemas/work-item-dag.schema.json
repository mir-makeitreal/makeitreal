{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Make It Real Work Item DAG Artifact",
  "description": "Schema for work-item-dag.json, the run-level dependency graph for Make It Real work items.",
  "type": "object",
  "required": [
    "edges",
    "nodes",
    "runId",
    "schemaVersion"
  ],
  "properties": {
    "schemaVersion": {
      "description": "Artifact schema version emitted by the Make It Real planner.",
      "type": "string",
      "const": "1.0"
    },
    "runId": {
      "description": "Identifier for the run packet that owns this DAG.",
      "type": "string",
      "minLength": 1
    },
    "nodes": {
      "description": "Work item nodes in the dependency graph.",
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/node"
      }
    },
    "edges": {
      "description": "Directed dependencies between work item nodes.",
      "type": "array",
      "items": {
        "$ref": "#/definitions/edge"
      }
    }
  },
  "additionalProperties": false,
  "definitions": {
    "node": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "requiredForDone",
        "responsibilityUnitId"
      ],
      "properties": {
        "id": {
          "description": "Work item id represented by this DAG node.",
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "description": "Role of the node in the work graph.",
          "type": "string",
          "enum": [
            "implementation",
            "domain-pm",
            "integration-evidence"
          ]
        },
        "requiredForDone": {
          "description": "Whether this node must complete before the run can be Done.",
          "type": "boolean"
        },
        "responsibilityUnitId": {
          "description": "Responsibility unit associated with this DAG node.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "edge": {
      "type": "object",
      "required": [
        "from",
        "to",
        "kind"
      ],
      "properties": {
        "from": {
          "description": "Source work item id.",
          "type": "string",
          "minLength": 1
        },
        "to": {
          "description": "Target work item id.",
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "description": "Dependency relationship kind.",
          "type": "string",
          "enum": [
            "contract-dependency",
            "coordination",
            "integration-proof"
          ]
        },
        "contractId": {
          "description": "Contract identifier required by contract-dependency and integration-proof edges.",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  }
}
